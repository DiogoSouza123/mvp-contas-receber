      "id": "22b44377-4361-4c60-b3f5-51b54bcae007",
      "name": "Get Boleto By Cprf",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1620,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const account = $item(0).$node[\"Expand Overdue Accounts\"].json;\nconst contactsResponse = $item(0).$node[\"Get Client Contacts\"].json;\nconst contacts = contactsResponse.Contatos || [];\nconst defaultContact = contacts[0];\nconst phone = defaultContact?.ContatosTelefone?.[0]?.Telefone;\nif (!phone) {\n  return [];\n}\nconst boletos = $json.Boletos || [];\nconst boleto = boletos.find((item) => item.Vencimento === account.vencimento) || boletos[0];\nif (!boleto) {\n  return [];\n}\nconst amount = Number(account.total || 0).toFixed(2).replace('.', ',');\nconst chatId = phone.includes('@') ? phone : `${phone}@c.us`;\nconst text = `${account.initialMessage}\\nCliente: ${account.clienteNome}\\nDocumento: ${account.documento}\\nVencimento: ${account.vencimento}\\nValor: R$ ${amount}\\nLinha digitavel: ${boleto.LinhaDigitavel}`;\nreturn [\n  {\n    json: {\n      ...account,\n      phone,\n      chatId,\n      boletoId: boleto.Identificador,\n      linhaDigitavel: boleto.LinhaDigitavel,\n      text\n    }\n  }\n];"
      },
      "id": "b34c31a0-1fd4-4eff-b8fd-bd45f6db5008",
      "name": "Prepare WhatsApp Charge",
