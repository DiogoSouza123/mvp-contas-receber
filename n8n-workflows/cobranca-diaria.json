      "position": [
        440,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const today = new Date();\nconst finalDate = new Date(today);\nfinalDate.setDate(finalDate.getDate() - 5);\nconst initialDate = new Date(today);\ninitialDate.setDate(initialDate.getDate() - 90);\nconst format = (value) => value.toISOString().slice(0, 10);\nreturn [\n  {\n    json: {\n      key: 'demo',\n      tenantId: 1,\n      dataInicial: format(initialDate),\n      dataFinal: format(finalDate),\n      initialMessage: $json.InitialWhatsAppMessage,\n      fallbackMessage: $json.DefaultFallbackMessage\n    }\n  }\n];"
      },
      "id": "6bd43fcb-36ee-44c2-8a86-90d7f28ff003",
      "name": "Build Date Window",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        300
      ]
    },
    {
      "parameters": {
        "url": "http://api:3000/Liftflex_API/rest/v2/GetContasReceberByVencimento",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "Key",
              "value": "={{$json.key}}"
            },
            {
              "name": "DataInicial",
              "value": "={{$json.dataInicial}}"
            },
            {
              "name": "DataFinal",
              "value": "={{$json.dataFinal}}"
            }
          ]
        },
        "options": {}
      },
      "id": "8d88f593-fa45-4df6-9a97-f6aef2e83004",
      "name": "Get Overdue Accounts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        900,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const settings = $item(0).$node[\"Build Date Window\"].json;\nconst accounts = $json.Dados || [];\nreturn accounts.map((entry) => ({\n  json: {\n    key: settings.key,\n    tenantId: settings.tenantId,\n    initialMessage: settings.initialMessage,\n    contaId: entry.Conta.Id,\n    clienteId: entry.Pagador.Id,\n    clienteNome: entry.Pagador.Nome,\n    cprf: entry.Pagador.Cnpj || entry.Pagador.Cpf,\n    vencimento: entry.Conta.DataVencimento,\n    total: entry.Conta.Total,\n    historico: entry.Conta.Historico,\n    documento: entry.Conta.Documento\n  }\n}));"
      },
      "id": "f1dcb06f-e8cb-4ac2-92dd-57cb27c47005",
      "name": "Expand Overdue Accounts",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1140,
        300
      ]
    },
    {
      "parameters": {
        "url": "http://api:3000/Liftflex_API/rest/v2/GetContatoCliente",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "Key",
              "value": "={{$json.key}}"
            },
            {
              "name": "ClienteId",
              "value": "={{$json.clienteId}}"
            }
          ]
        },
        "options": {}
      },
      "id": "2cdfefb4-c47a-4b2a-991d-1d58dd1fe006",
      "name": "Get Client Contacts",
