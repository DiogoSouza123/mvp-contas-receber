    {
      "parameters": {
        "url": "http://api:3000/Liftflex_API/rest/v2/GetBoletoByCprf",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "Cprf",
              "value": "={{$node[\"Expand Overdue Accounts\"].json.cprf}}"
            },
            {
              "name": "TenantId",
              "value": "={{$node[\"Expand Overdue Accounts\"].json.tenantId}}"
